<?xml version="1.0"?>

<robot name="bumperbot" xmlns:xacro="http://ros.org/wiki/xacro">

  <!-- Start GZ or Ignition depending on ROS 2 Version -->
  <xacro:arg name="is_ignition" default="true"/>

  <!-- Include Gazebo Parameters -->
  <xacro:include filename="$(find bumperbot_description)/urdf/bumperbot_gazebo.xacro" />

  <!-- Include ros2_control Plugins -->
  <xacro:include filename="$(find bumperbot_description)/urdf/bumperbot_ros2_control.xacro" />

  <link name="base_footprint"/>
  
  <link name="base_link">
    <inertial>
      <origin xyz="0.0065 0.002607 0.020274" rpy="0 0 0"/>
      <mass value="0.947792"/>
      <inertia ixx="3.036"    ixy="-0.4767"  ixz="-0.511"
               iyy="1.659"    iyz="-1.036"
               izz="3.374" />
    </inertial>
    <visual>
      <origin xyz="0 0 0.0015" rpy="0 0 1.57" />
      <material name="black"/>
      
      <geometry>
        <mesh filename="package://bumperbot_description/meshes/base_link.stl" scale="0.001 0.001 0.001"/>
      </geometry>
    </visual>
    <collision>
      <origin xyz="0 0 0.0015" rpy="0 0 1.57" />
      <geometry>
        <mesh filename="package://bumperbot_description/meshes/base_link.stl" scale="0.001 0.001 0.001"/>
      </geometry>
    </collision>
  </link>

  <joint name="base_joint" type="fixed">
    <parent link="base_footprint"/>
    <child link="base_link" />
    <origin xyz="0 0 0.038" rpy="0 0 0"/>
  </joint>

  <link name="wheel_right_link">
    <inertial>
      <origin xyz="6.671e-12 -1.094e-11 0.012102" rpy="0 0 0"/>
      <mass value="0.09205" />
      <inertia ixx="9.3607e-05"  ixy="-4.428e-15"  ixz="6.941e-16"
               iyy="9.3607e-05"  iyz="-1.133e-15"
               izz="1.802e-04" />
    </inertial>
    <visual>
      <origin xyz="0 0 0" rpy="-1.57 0 0" />
      <material name="blue" />
      <geometry>
        <mesh filename="package://bumperbot_description/meshes/wheel_right_link.stl" scale="0.001 0.001 0.001"/>
      </geometry>
    </visual>
    <collision>
      <origin xyz="0 0 0" rpy="-1.57 0 0" />
      <geometry>
        <mesh filename="package://bumperbot_description/meshes/wheel_right_link.stl" scale="0.001 0.001 0.001"/>
      </geometry>
    </collision>
  </link>

  <joint name="wheel_right_joint" type="continuous">
    <origin xyz="0 -0.14355 0.015" rpy="0 0 0" />
    <parent link="base_link" />
    <child link="wheel_right_link" />
    <axis xyz="0 1 0" />
  </joint>
  
  <link
    name="wheel_left_link">
    <inertial>
      <origin xyz="6.671e-12 -1.094e-11 0.012102" rpy="0 0 0" />
      <mass value="0.09205" />
      <inertia ixx="9.3607e-05"  ixy="-4.428e-15"  ixz="6.941e-16"
               iyy="9.3607e-05"  iyz="-1.133e-15"
               izz="1.802e-04" />
    </inertial>
    <visual>
      <origin xyz="0 0 0" rpy="1.57 0 0" />
      <material name="blue" />
      <geometry>
        <mesh filename="package://bumperbot_description/meshes/wheel_left_link.stl" scale="0.001 0.001 0.001"/>
      </geometry>
    </visual>
    <collision>
      <origin xyz="0 0.015 0" rpy="1.57 0 0" />
      <geometry>
        <mesh filename="package://bumperbot_description/meshes/wheel_left_link.stl" scale="0.001 0.001 0.001"/>
      </geometry>
    </collision>
  </link>

  <joint name="wheel_left_joint" type="continuous">
    <origin xyz="0 0.14355 0.015" rpy="0 0 0" />
    <parent link="base_link" />
    <child link="wheel_left_link" />
    <axis xyz="0 1 0" />
  </joint>

  <link name="caster_front_link">
    <inertial>
      <origin xyz="0.000348 -0.003895 0.018625" rpy="0 0 0" />
      <mass value="0.030003" />
      <inertia ixx="5.032352e-06"  ixy="7.6e-10"    ixz="-5.91e-10"
               iyy="5.178243e-06"  iyz="-2.92e-10"
               izz="5.249228e-06" />
    </inertial>
    <visual>
      <origin xyz="0 0 0" rpy="0 0 1.57" />
      <material name="silver"/>
      <geometry>
        <mesh filename="package://bumperbot_description/meshes/caster_front_link.stl" scale="0.001 0.001  0.001"/>
      </geometry>
    </visual>
    <collision>
      <origin xyz="0 0 0" rpy="0 0 1.57" />
      <geometry>
        <mesh filename="package://bumperbot_description/meshes/caster_front_link.stl" scale="0.001 0.001  0.001"/>
      </geometry>
    </collision>
  </link>

  <joint name="caster_front_joint" type="fixed">
    <origin xyz="0.0762 0 -0.0345011" rpy="0 0 0" />
    <parent link="base_link" />
    <child link="caster_front_link" />
  </joint>
  
  <link name="caster_rear_link">
    <inertial>
      <origin xyz="0.000348 -0.003895 0.018625" rpy="0 0 0" />
      <mass value="0.030003" />
      <inertia ixx="5.032352e-06"  ixy="7.6e-10"    ixz="-5.91e-10"
               iyy="5.178243e-06"  iyz="-2.92e-10"
               izz="5.249228e-06" />
    </inertial>
    <visual>
      <origin xyz="0 0 0" rpy="0 0 1.57" />
      <material name="silver"/>
      <geometry>
        <mesh filename="package://bumperbot_description/meshes/caster_rear_link.stl" scale="0.001 0.001  0.001"/>
      </geometry>
    </visual>
    <collision>
      <origin xyz="0 0 0" rpy="0 0 1.57" />
      <geometry>
        <mesh filename="package://bumperbot_description/meshes/caster_rear_link.stl" scale="0.001 0.001  0.001"/>
      </geometry>
    </collision>
  </link>

  <joint name="caster_rear_joint" type="fixed">
    <origin xyz="0.0762 0 -0.0345011" rpy="0 0 0" />
    <parent link="base_link" />
    <child link="caster_rear_link" />
  </joint>

  <link name="laser">
        <inertial>
            <origin xyz="0.0000267575 0.0000021499 0.0000258840" rpy="0 0 0"/>
            <mass value="0.1700"/>
            <inertia ixx="7.403494e-05"  ixy="5.337393e-06"  ixz="1.511932e-05"
                                            iyy="1.426408e-04"  iyz="1.752534e-06"
                                                                izz="1.672852e-04"/>
        </inertial>

        <visual>
            <geometry>
                <mesh filename="package://bumperbot_description/meshes/new_laser_link.stl"/>    
            </geometry>
            <origin xyz="0 0 0" rpy="0 0 0"/>
            <material name="dark_grey"/>
        </visual>

        <collision>
            <geometry>
                <mesh filename="package://bumperbot_description/meshes/new_laser_link.stl"/>    
            </geometry>
            <origin xyz="0 0 0" rpy="0 0 0"/>
        </collision>
    </link>

    <joint name="laser_joint" type="fixed">
        <origin xyz="0 0 0.131" rpy="0 0 0" /> <!-- z= 0.042(from physical unit) + 0.088(from fusion final assembly without wheels) + 0.001(accounting for plate thickness)-->
        <parent link="base_link" />
        <child link="laser" />
    </joint>
  
  <material name="blue">
    <color rgba="0 0 1 1"/>
  </material>
  
  <material name="black">
    <color rgba="0 0 0 1"/>
  </material>
  
  <material name="silver">
    <color rgba="0.79 0.82 0.93 1"/>
  </material>
  
  <material name="dark_grey">
    <color rgba="0.3 0.3 0.3 1"/>
  </material>

  <material name="amber_gold">
    <color rgba="1.0 0.75 0.0 1.0"/>
  </material>

</robot>