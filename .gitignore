# --- ROS 2 Build Folders ---
# These are generated by 'colcon build' and are machine-specific
build/
install/
log/

# --- IDE Settings ---
# IntelliJ / PyCharm settings (the .idea folder you have)
.idea/
# VS Code settings (if you ever use it)
.vscode/

# --- Python & OS Junk ---
__pycache__/
*.pyc
*.pyo
.DS_Store
